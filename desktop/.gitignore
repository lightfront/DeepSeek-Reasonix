# Wails build assets/output — all auto-generated from defaults (icons, plists,
# manifests, compiled binary); `wails dev`/`wails build` regenerate what's missing.
# Un-ignore specific files here once you customize them (e.g. a real app icon).
/build/

# Go test binaries
*.test

# Local config symlinks for `wails dev` (point at the repo-root reasonix.toml/.env
# so the desktop app resolves the same config/keys the CLI does). Never commit.
/reasonix.toml
/.env
